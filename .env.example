# Environment Configuration for Umusa Skills Website

# ============================================
# REQUIRED for production/Cloud Run deployment
# ============================================

# Inbound.new Email API Key (for contact form emails)
# Get this from: https://inbound.new/settings
# Click "Create API Key", give it a name, and paste the value here
INBOUND_API_KEY=your_inbound_api_key_here

# ============================================
# Optional - For development
# ============================================

# Node environment
# Values: development | production
NODE_ENV=production

# Server port (Cloud Run sets this automatically, but you can override)
PORT=8080

# Disable reusePort for Cloud Run (where it's not supported)
# Cloud Run automatically sets this to "true"
DISABLE_REUSE_PORT=true

# Database URL (if you have a database)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ============================================
# Cloud Run Deployment Steps
# ============================================
#
# 1. Build and push to Google Container Registry:
#    gcloud builds submit --tag gcr.io/PROJECT_ID/umusa-skills-website
#
# 2. Deploy to Cloud Run:
#    gcloud run deploy umusa-skills-website \
#      --image gcr.io/PROJECT_ID/umusa-skills-website \
#      --platform managed \
#      --region us-central1 \
#      --allow-unauthenticated \
#      --set-env-vars INBOUND_API_KEY=your_key_here \
#      --memory 512Mi \
#      --timeout 60
#
# 3. Set up custom domain with Cloudflare:
#    - In Cloud Run, add custom domain
#    - In Cloudflare, add CNAME record pointing to Cloud Run
#
# ============================================
# Important Notes
# ============================================
#
# - Do NOT commit this file with actual secrets
# - Use Cloud Run's "Set up with Secret Manager" for sensitive values
# - The PORT environment variable is automatically set by Cloud Run to 8080
# - DISABLE_REUSE_PORT is set automatically in the Dockerfile for Cloud Run
# - For local development, copy this to .env and fill in test values
#
